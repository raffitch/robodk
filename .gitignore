# The RoboDK station is a ~117 MB binary. We version the extracted Python, NOT the blob.
# (If you DO want the station in history, use Git LFS and remove the line below.)
241113_AutoScan.rdk
*.synced.rdk

# Secrets - device passwords, tokens. NEVER commit these.
secrets/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# tasni app: per-run calibration/scan artifacts + local config overrides
runs/
tasni.config.json

# RoboDK temp
*.rdk.bak
